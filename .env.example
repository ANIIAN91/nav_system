# Database Configuration (Optional - defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./data/nav_system.db
# Docker entrypoint runs `alembic upgrade head` by default.
# Set SKIP_MIGRATIONS=true only if you run migrations separately.
# SKIP_MIGRATIONS=false
# Default app deployment also runs periodic log cleanup every 6 hours.
# ENABLE_LOG_CLEANUP=true
# LOG_CLEANUP_INTERVAL_SECONDS=21600
# MAX_VISIT_RECORDS=1000
# MAX_UPDATE_RECORDS=500

# Security Configuration (REQUIRED)
SECRET_KEY=generate-a-random-32-char-string-here
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# Login session lifetime in minutes. 43200 = 30 days.
ACCESS_TOKEN_EXPIRE_MINUTES=43200
